<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hhx.agi.infra.dao.PendingIntentMapper">

    <select id="selectByConversationId" resultType="com.hhx.agi.infra.po.PendingIntentPO">
        SELECT *
        FROM pending_intents
        WHERE conversation_id = #{conversationId}
        ORDER BY id
    </select>

    <delete id="deleteByConversationId">
        DELETE FROM pending_intents
        WHERE conversation_id = #{conversationId}
    </delete>

</mapper>