<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hhx.agi.infra.dao.SkillRegistryMapper">

    <select id="selectEnabledOrderByPriority" resultType="com.hhx.agi.infra.po.SkillRegistryPO">
        SELECT *
        FROM skill_registry
        WHERE enabled = #{enabled}
        ORDER BY priority DESC, id ASC
    </select>

</mapper>